{
  "name": "domain-placeholder-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "build:local": "dotenv -e .env -- pnpm build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:markdown": "markdownlint-cli2 \"**/*.{md,markdown}\" \"!node_modules\" \"!dist\" \"!.venv\"",
    "check:env": "tsx scripts/check-env-validation.ts",
    "inventory:drift-review": "tsx scripts/domain-drift-review.ts",
    "smoke": "node scripts/smoke-production.mjs",
    "check:a11y": "node scripts/check-accessibility.mjs",
    "validate": "pnpm format:check && pnpm lint && pnpm test && pnpm check:markdown && pnpm check:env && pnpm smoke && pnpm check:a11y"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "astro": "^6.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.17.0",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^17.6.0",
    "markdownlint-cli2": "^0.22.1",
    "pa11y": "^9.1.1",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.2",
    "vitest": "^4.1.6"
  }
}
