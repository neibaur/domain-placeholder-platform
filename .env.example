# Public configuration used by Astro at build time.
# These values are safe to expose in rendered HTML and client-side assets.
# Do not put secrets, account IDs, API tokens, registrant details, or private
# ownership metadata in PUBLIC_ variables.

# Canonical deployment origin. Cloudflare Pages projects should set this per
# custom domain, for example: https://68tai.com
PUBLIC_SITE_URL="https://example.com"

# Required: primary visible page title and default site label.
PUBLIC_SITE_TITLE="Domain Placeholder"

# Defaults to PUBLIC_SITE_TITLE when unset. Keep generic unless a domain
# intentionally needs a public brand name.
PUBLIC_SITE_NAME="Domain Placeholder"

# Defaults to a generic placeholder description when unset.
# SEO and accessibility description. Keep concise; this appears in metadata.
PUBLIC_SITE_DESCRIPTION="A lightweight placeholder page for a reserved domain."

# Defaults to en when unset. Use a BCP 47 language code.
PUBLIC_PRIMARY_LOCALE="en"

# Defaults to zh-CN when unset. Rendered alongside the primary message.
PUBLIC_SECONDARY_LOCALE="zh-CN"

# Defaults to an empty string when unset. Leave unset when no public URL exists.
PUBLIC_CONTACT_URL=""

# Defaults to false when unset. Use false for parked, private, test, or prelaunch
# domains that should not be indexed. Set true only when a deployment should
# intentionally allow search indexing.
PUBLIC_ROBOTS_INDEX="false"

# Future private/secret configuration belongs in deployment secret stores only.
# TODO(terraform): model Cloudflare Pages environment variables without storing secrets in git.
