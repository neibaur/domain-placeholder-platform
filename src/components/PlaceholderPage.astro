---
import type { PublicConfig } from "@/config/public";
import { getLocalizedPageContent } from "@/content/locales";

type Props = {
  config: PublicConfig;
};

const { config } = Astro.props;
const content = getLocalizedPageContent(config);
const { primary, secondary, visibleLocales } = content;
const localizedBlocks = [primary, ...(secondary ? [secondary] : [])];
---

<main class="page-shell" aria-labelledby="page-title">
  <section class="intro" aria-describedby="page-description">
    <p class="eyebrow">{primary.copy.eyebrow}</p>
    <h1 id="page-title">{config.PUBLIC_SITE_TITLE}</h1>
    <p id="page-description" class="lede">{config.PUBLIC_SITE_DESCRIPTION}</p>
  </section>

  <section class="status-grid" aria-labelledby="status-title">
    <h2 id="status-title" class="sr-only">{primary.copy.statusSectionLabel}</h2>
    <div>
      <span>{primary.copy.statusLabel}</span>
      <strong>{primary.copy.statusValue}</strong>
    </div>
    <div>
      <span>{primary.copy.domainLabel}</span>
      <strong>{new URL(config.PUBLIC_SITE_URL).hostname}</strong>
    </div>
    <div>
      <span>{primary.copy.localesLabel}</span>
      <strong>{visibleLocales.join(" / ")}</strong>
    </div>
  </section>

  <section class="message" aria-labelledby="message-title">
    <h2 id="message-title" class="sr-only">
      {primary.copy.messageSectionLabel}
    </h2>
    {
      localizedBlocks.map(({ locale, copy }) => (
        <article class="locale-card" lang={locale}>
          <h3>{copy.heading}</h3>
          <p>{copy.description}</p>
        </article>
      ))
    }
  </section>

  {
    config.PUBLIC_CONTACT_URL ? (
      <p class="contact">
        <a href={config.PUBLIC_CONTACT_URL}>{primary.copy.contactLabel}</a>
      </p>
    ) : null
  }
</main>
